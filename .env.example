MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/road-rescue?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-strong-secret
PORT=5001
VITE_API_URL=http://localhost:5001

# Razorpay — server: dashboard key id + secret (https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Client: same Key ID only (safe to expose). Rebuild frontend after changing.
VITE_RAZORPAY_KEY_ID=

# Google AI (Gemini) — used only on the server. Never commit a real key.
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: gemini-2.0-flash, gemini-1.5-flash, etc.
GEMINI_MODEL=gemini-2.0-flash

# AI provider mode: auto | ollama | gemini
AI_PROVIDER=auto
# Optional: local open model endpoint (for Ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
# Optional: choose your local model
OLLAMA_MODEL=llama3.1:8b

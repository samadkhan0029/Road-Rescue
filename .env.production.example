# Production Environment Variables for Vercel Deployment
NODE_ENV=production

# MongoDB Configuration (Required for production)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/roadrescue

# JWT Secret (Required - Generate a strong secret)
JWT_SECRET=your-super-secret-jwt-key-change-in-production-2024

# Twilio Configuration (Optional - for WhatsApp OTP)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=whatsapp:+14155238886

# Email Configuration (Optional - for email notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# API Keys (Optional)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# Frontend URL (Vercel will set this automatically)
FRONTEND_URL=https://your-app.vercel.app

# Geoapify API Key (Already in vite.config.js)
VITE_GEOAPIFY_API_KEY=2147625628e7408baf97ef929225f25a
